rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function isPrivilegedEmail() {
      return isSignedIn() && authEmail() == 'f20240819@hyderabad.bits-pilani.ac.in';
    }

    function isWhitelistedAuthEmail() {
      return isSignedIn() && exists(/databases/$(database)/documents/whitelist/$(authEmail()));
    }

    function isAllowedEmail() {
      return isPrivilegedEmail() || isWhitelistedAuthEmail();
    }

    function userDocExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveMember() {
      return isAllowedEmail() && userDocExists() && userDoc().status == 'active';
    }
  
    function isAdmin() {
      return isActiveMember() && userDoc().role in ['SPT', 'JPT'];
    }
    
    function isSpt() {
      return isActiveMember() && userDoc().role == 'SPT';
    }

    function validSelfCreate(userId) {
      return request.resource.data.keys().hasOnly(['id', 'name', 'role', 'avatar', 'email', 'isOnHoliday', 'status']) &&
        request.resource.data.id == userId &&
        request.resource.data.email == authEmail() &&
        request.resource.data.isOnHoliday == false &&
        request.resource.data.status == 'active' &&
        (
          (isPrivilegedEmail() && request.resource.data.role == 'SPT') ||
          (!isPrivilegedEmail() && request.resource.data.role == 'Associate')
        );
    }

    function validSelfProfileUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['name', 'avatar', 'isOnHoliday']);
    }

    match /users/{userId} {
      allow read: if isActiveMember() && (request.auth.uid == userId || isSpt());
      allow create: if isSignedIn() && request.auth.uid == userId && isAllowedEmail() && validSelfCreate(userId);
      allow update: if isSpt() || (isActiveMember() && request.auth.uid == userId && validSelfProfileUpdate());
    }

    match /tasks/{taskId} {
      allow read: if isActiveMember();
      allow create: if isAdmin();
      allow update: if isActiveMember() && (
        resource.data.createdBy == request.auth.uid || // Creator can update
        request.auth.uid in resource.data.assignedTo // Assigned users can update
      );
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isActiveMember() && (
          request.auth.uid == get(/databases/$(database)/documents/tasks/$(taskId)).data.createdBy ||
          request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.assignedTo ||
          isAdmin()
        );
      }
    }

    match /announcements/{announcementId} {
      allow read: if isActiveMember();
      allow create, update, delete: if isAdmin();
    }
    
    match /resources/{resourceId} {
       allow read: if isActiveMember();
       allow create, delete: if isAdmin();
       allow update: if isAdmin() || isActiveMember();
    }

    match /whitelist/{email} {
      allow read, write: if isSpt();
    }
    
    match /blacklist/{email} {
       allow read, write: if isSpt();
    }

  }
}
